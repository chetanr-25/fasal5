// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Users table
model User {
  id                 String           @id @default(uuid())
  pincode            String
  location_name      String
  district           String
  state              String
  farm_area_acres    Float
  farm_area_hectares Float
  phone              String           @unique
  preferred_language String           @default("en") // "en" for English, "hi" for Hindi
  created_at         DateTime         @default(now())
  updated_at         DateTime         @updatedAt
  recommendations    Recommendation[]
  chatHistory        ChatHistory[]
}

// Crops table
model Crop {
  id                      String       @id @default(uuid())
  name_en                 String
  name_hi                 String
  season                  String
  soil_ph_min             Float
  soil_ph_max             Float
  temperature_min         Float
  temperature_max         Float
  rainfall_min            Float
  rainfall_max            Float
  investment_per_acre     Float
  expected_yield_per_acre Float
  current_market_price    Float
  roi_percentage          Float
  growing_states          String[]
  fertilizers             Fertilizer[]
  pesticides              Pesticide[]
}

// Weather data
model Weather {
  id                String   @id @default(uuid())
  pincode           String   @unique
  location_name     String
  current_temp      Float
  humidity          Float
  rainfall          Float
  wind_speed        Float
  weather_condition String
  forecast_7day     Json
  last_updated      DateTime @default(now())
}

// Soil data
model Soil {
  id               String @id @default(uuid())
  pincode          String @unique
  district         String
  state            String
  ph_level         Float
  nitrogen         Float
  phosphorus       Float
  potassium        Float
  organic_matter   Float
  moisture_content Float
  soil_type        String
}

// Market prices
model MarketPrice {
  id               String   @id @default(uuid())
  crop_name        String
  mandi_location   String
  state            String
  min_price        Float
  max_price        Float
  modal_price      Float
  arrival_quantity Float
  price_date       DateTime

  @@unique([crop_name, mandi_location, price_date])
}

// Fertilizers
model Fertilizer {
  id                String @id @default(uuid())
  crop              Crop   @relation(fields: [crop_id], references: [id])
  crop_id           String
  fertilizer_name   String
  application_stage String
  quantity_per_acre Float
  frequency_days    Int
  cost_per_kg       Float
}

// Pesticides
model Pesticide {
  id                 String @id @default(uuid())
  crop               Crop   @relation(fields: [crop_id], references: [id])
  crop_id            String
  pest_disease_name  String
  pesticide_name     String
  application_timing String
  spray_frequency    Int
  cost_per_liter     Float
}

// Recommendations
model Recommendation {
  id                  String   @id @default(uuid())
  user                User     @relation(fields: [user_id], references: [id])
  user_id             String
  recommended_crops   String[]
  recommendation_date DateTime @default(now())
  confidence_score    Float
  reasoning           String
}

// Chat History
model ChatHistory {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [user_id], references: [id])
  user_id    String
  query      String
  response   String   @db.Text
  created_at DateTime @default(now())
}
